class ContaBancaria:
    """
    cria uma conta bancaria e permite fazer saques e depositos
    """

    def __init__(self, id, nome, saldo=0):
        self.id = id
        self.titular = nome
        self.saldo = saldo

    def __str__(self):
        return f"Conta {self.id}: de {self.titular} tem R$ {self.saldo}"

    def depositar(self, valor):
        self.saldo += valor

    def sacar(self, valor):
        if valor <= self.saldo:
            self.saldo -= valor
        else:
            print("Saldo insuficiente")


c1 = ContaBancaria(id=112, nome="Thiago", saldo=3000)
c1.depositar(500)

